require "shellwords"

# iOS のみをリリース対象とする方針（Android は配信しない）。
default_platform(:ios)

XCODEPROJ  = "ios/ModernJamaica.xcodeproj"
WORKSPACE  = "ios/ModernJamaica.xcworkspace"
SCHEME     = "ModernJamaica"
APP_ID     = "com.junt.modernjamaica"
TEAM_ID    = "JD7L34U2WS"

platform :ios do
  desc "Release ビルドを作成し TestFlight へアップロードする"
  desc "使い方: bundle exec fastlane ios beta version:1.1.4 changelog:\"広告設定の修正\""
  desc ""
  desc "必要な環境変数（CI では GitHub Secrets から注入）:"
  desc "  ASC_KEY_ID    … App Store Connect API キーの Key ID"
  desc "  ASC_ISSUER_ID … 同 Issuer ID（チーム共通）"
  desc "  ASC_KEY_PATH  … ダウンロードした AuthKey_*.p8 のパス"
  lane :beta do |options|
    key_id    = ENV.fetch("ASC_KEY_ID")
    issuer_id = ENV.fetch("ASC_ISSUER_ID")
    key_path  = File.expand_path(ENV.fetch("ASC_KEY_PATH"))

    # クラウド管理の配布証明書を自動生成するには Admin ロールのキーが必要。
    api_key = app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_filepath: key_path,
      duration: 1200,
    )

    version = (options[:version] ||
      get_info_plist_value(path: "ios/ModernJamaica/Info.plist", key: "CFBundleShortVersionString")).to_s.strip
    UI.user_error!("marketing version が空です。version:X.Y.Z を渡してください") if version.empty?

    # 同じバージョン列(train)の最新ビルド番号 + 1。新規 train なら 1 から。
    # 公開済みバージョンより低いと弾かれるため、常に単調増加させる。
    latest = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: APP_ID,
      version: version,
      initial_build_number: 0,
    )
    build_number = latest.to_i + 1
    UI.important("Releasing #{version} (build #{build_number}) to TestFlight")

    # apple-generic versioning のため、ビルド設定と Info.plist の両方を確実に揃える。
    increment_version_number(version_number: version, xcodeproj: XCODEPROJ)
    increment_build_number(build_number: build_number, xcodeproj: XCODEPROJ)

    build_app(
      workspace: WORKSPACE,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      # API キーでクラウド配布署名を自動プロビジョニング（証明書をリポジトリに置かない）。
      xcargs: [
        "-allowProvisioningUpdates",
        "-authenticationKeyPath #{key_path.shellescape}",
        "-authenticationKeyID #{key_id}",
        "-authenticationKeyIssuerID #{issuer_id}",
      ].join(" "),
      export_options: {
        signingStyle: "automatic",
        teamID: TEAM_ID,
        uploadSymbols: true,
      },
      output_directory: "build",
      output_name: "ModernJamaica.ipa",
      clean: true,
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: APP_ID,
      # 内部テスターのみ（Beta App Review 不要）。外部配信は別途 true にする。
      distribute_external: false,
      skip_waiting_for_build_processing: true,
      changelog: (options[:changelog].to_s.empty? ? nil : options[:changelog]),
    )

    UI.success("Uploaded #{version} (#{build_number}). App Store Connect で処理完了後、内部テスターに配信されます。")
  end

  desc "App Store の What's New(リリースノート)とスクリーンショットを反映する（バイナリは送らない）"
  desc "使い方: bundle exec fastlane ios metadata version:1.1.4"
  desc ""
  desc "反映するのは fastlane/metadata/ja/release_notes.txt と fastlane/screenshots/ja/*.png のみ。"
  desc "タイトル・サブタイトル・説明・キーワード・宣伝文など既存メタデータは意図的に置いていない"
  desc "ため上書きされない（App Store Connect の現行値を維持）。審査提出もしない。"
  desc "必要な環境変数は beta レーンと同じ（ASC_KEY_ID / ASC_ISSUER_ID / ASC_KEY_PATH）。"
  lane :metadata do |options|
    key_id    = ENV.fetch("ASC_KEY_ID")
    issuer_id = ENV.fetch("ASC_ISSUER_ID")
    key_path  = File.expand_path(ENV.fetch("ASC_KEY_PATH"))

    api_key = app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_filepath: key_path,
      duration: 1200,
    )

    version = (options[:version] ||
      get_info_plist_value(path: "ios/ModernJamaica/Info.plist", key: "CFBundleShortVersionString")).to_s.strip
    UI.user_error!("marketing version が空です。version:X.Y.Z を渡してください") if version.empty?
    UI.important("Uploading App Store metadata & screenshots for #{version}")

    upload_to_app_store(
      api_key: api_key,
      app_identifier: APP_ID,
      app_version: version,
      # メタデータ本文とスクショのみ。ビルド(ipa)は beta レーン/CI で別途アップロード。
      skip_binary_upload: true,
      # 既存スクショを今回の6枚で置き換える。
      overwrite_screenshots: true,
      # CI で対話プレビュー(HTML)を出さない。
      force: true,
      run_precheck_before_submit: false,
      precheck_include_in_app_purchases: false,
      # 審査提出はしない。App Store Connect 上で内容を確認してから手動提出する。
      submit_for_review: false,
      languages: ["ja"],
      metadata_path: "./fastlane/metadata",
      screenshots_path: "./fastlane/screenshots",
    )

    UI.success("Metadata & screenshots uploaded for #{version}. App Store Connect で確認し、手動で審査提出してください。")
  end

  desc "本番リリース: 最新ビルドを紐付けて審査提出する（メタデータ/スクショは触らない）"
  desc "使い方: bundle exec fastlane ios release version:1.1.4"
  desc ""
  desc "- What's New とスクショは事前に `metadata` レーンで反映しておくこと。ここでは再アップロードしない"
  desc "  （deliver 再アップロードによるスクショ重複を避けるため、掃除と提出を分離）"
  desc "- 輸出コンプライアンス: 非該当（暗号化なし。Info.plist の ITSAppUsesNonExemptEncryption=false と整合）"
  desc "- 広告識別子(IDFA): 使用しない（ATT 未実装。AdMob は SKAdNetwork で配信・計測）"
  desc "- 審査承認後は自動で公開（automatic_release）"
  desc "必要な環境変数は beta レーンと同じ（ASC_KEY_ID / ASC_ISSUER_ID / ASC_KEY_PATH）。"
  lane :release do |options|
    key_id    = ENV.fetch("ASC_KEY_ID")
    issuer_id = ENV.fetch("ASC_ISSUER_ID")
    key_path  = File.expand_path(ENV.fetch("ASC_KEY_PATH"))

    api_key = app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_filepath: key_path,
      duration: 1200,
    )

    version = (options[:version] ||
      get_info_plist_value(path: "ios/ModernJamaica/Info.plist", key: "CFBundleShortVersionString")).to_s.strip
    UI.user_error!("marketing version が空です。version:X.Y.Z を渡してください") if version.empty?
    UI.important("Submitting #{version} for App Store review (auto-release)")

    upload_to_app_store(
      api_key: api_key,
      app_identifier: APP_ID,
      app_version: version,
      # バイナリは TestFlight/CI で既にアップロード済み。該当バージョンの最新ビルドを紐付ける。
      skip_binary_upload: true,
      # メタデータ(What's New)とスクショは `metadata` レーンで反映済み。ここでは一切触らず提出のみ行う。
      # deliver の再アップロード時の ASC 結果整合性の競合でスクショが重複するのを防ぐため。
      skip_metadata: true,
      skip_screenshots: true,
      force: true,
      run_precheck_before_submit: false,
      precheck_include_in_app_purchases: false,
      # 審査提出＋承認後の自動公開。
      submit_for_review: true,
      automatic_release: true,
      submission_information: {
        export_compliance_uses_encryption: false,
        add_id_info_uses_idfa: false,
      },
    )

    UI.success("Submitted #{version} for review. 承認後に自動公開されます。")
  end
end
